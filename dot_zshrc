# yt-dlp with LLM-generated commands
YT_DL_DEFAULTS='Always download in mp4 format unless the user specifies otherwise. Always use the output template "%(title)s.%(ext)s" unless the user specifies a different filename or template.'

yt-dl() {
  local url="$1" instructions="$2"
  if [[ -z "$url" ]]; then
    echo "Error: missing video URL" >&2
    echo "Usage: yt-dl <url> <instructions>" >&2
    return 1
  fi
  if [[ -z "$instructions" ]]; then
    echo "Error: missing download instructions" >&2
    echo "Usage: yt-dl <url> <instructions>" >&2
    return 1
  fi
  if [[ -z "$OPENAI_API_KEY" ]]; then
    echo "Error: OPENAI_API_KEY is not set" >&2
    return 1
  fi
  if ! command -v yt-dlp &>/dev/null; then
    echo "Error: yt-dlp is not installed" >&2
    return 1
  fi

  local manual_file="$HOME/.local/share/yt-dlp/manual.txt"
  if [[ ! -s "$manual_file" ]]; then
    echo "Error: yt-dlp manual not found at $manual_file" >&2
    return 1
  fi

  local manual=$(<"$manual_file")

  local payload
  payload=$(jq -n \
    --arg manual "$manual" \
    --arg url "$url" \
    --arg instructions "$instructions" \
    --arg defaults "$YT_DL_DEFAULTS" \
    --arg sysprompt "You are a yt-dlp command generator. Given the yt-dlp manual and a user request, output ONLY the raw yt-dlp command to run. No explanation, no markdown, no code fences. The command must start with \"yt-dlp\"." \
    '{
      model: "gpt-5.4-mini",
      reasoning: { effort: "medium" },
      input: [
        {
          role: "developer",
          content: ($sysprompt + "\n\nUser'\''s preferences: " + $defaults + "\n\nyt-dlp manual:\n" + $manual)
        },
        {
          role: "user",
          content: ("URL: " + $url + "\nInstructions: " + $instructions)
        }
      ]
    }')

  echo "Generating command..." >&2
  local response
  response=$(curl -s https://api.openai.com/v1/responses \
    -H "Content-Type: application/json" \
    -H "Authorization: Bearer $OPENAI_API_KEY" \
    -d "$payload")

  local cmd
  cmd=$(echo "$response" | jq -r '
    [.output[] | select(.type == "message") | .content[] | select(.type == "output_text") | .text]
    | first // empty
  ')

  if [[ -z "$cmd" ]]; then
    echo "Error: failed to generate command" >&2
    echo "$response" | jq -r '.error.message // .' >&2
    return 1
  fi

  echo "Command: $cmd" >&2
  read -q "confirm?Run this command? [y/N] " || { echo >&2; return 0; }
  echo >&2

  eval "noglob $cmd"
}


